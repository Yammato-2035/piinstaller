#!/bin/bash
# Rescue live network onboarding — WLAN scan/connect without password logging.
set -uo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=setuphelfer-rescue-common.sh
source "${SCRIPT_DIR}/setuphelfer-rescue-common.sh"
set +e

MODE="${1:---interactive}"
OUT_RUN="${SETUPHELFER_RESCUE_STATE_DIR}/network-onboarding.json"
OUT_TMP="/tmp/setuphelfer-rescue-network-onboarding.json"
WIFI_CONNECTED=false
DEFAULT_ROUTE=false
TELEMETRY_OK=false
ERROR_CODE=""
EXIT_CODE=0
INTERACTIVE=false
CONFIG_SOURCE="none"
OFFLINE_MODE=false

setuphelfer_rescue_ensure_state_dir
setuphelfer_rescue_load_network_env || true
setuphelfer_rescue_resolve_telemetry_urls
TELEMETRY_HEALTH_URL="${SETUPHELFER_RESCUE_TELEMETRY_HEALTH_URL}"

if ! setuphelfer_rescue_is_live; then
  ERROR_CODE="NOT_RESCUE_LIVE"
  EXIT_CODE=16
elif [[ "$MODE" == "--boot-trigger" ]]; then
  if setuphelfer_rescue_is_qemu && [[ "${SETUPHELFER_RESCUE_NETWORK_ONBOARDING_FORCE:-}" != "1" ]]; then
    ERROR_CODE="SKIPPED_QEMU_LAB"
    EXIT_CODE=0
  elif ! grep -Eq 'setuphelfer_network_onboarding=1' /proc/cmdline 2>/dev/null; then
    ERROR_CODE="SKIPPED_BOOT_WAIT_USER"
    EXIT_CODE=0
    setuphelfer_rescue_write_json "$OUT_RUN" <<EOF
{
  "checked_at": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "mode": "$MODE",
  "status": "skipped",
  "reason": "network_onboarding_waits_for_user_action",
  "exit_code": 0,
  "secrets_exposed": false
}
EOF
    cp -f "$OUT_RUN" "$OUT_TMP" 2>/dev/null || true
    touch "${SETUPHELFER_RESCUE_STATE_DIR}/network-onboarding.done" 2>/dev/null || true
    exit 0
  elif grep -Eq 'setuphelfer_network_onboarding=1' /proc/cmdline 2>/dev/null; then
    INTERACTIVE=true
  fi
elif [[ "$MODE" == "--non-interactive" ]]; then
  INTERACTIVE=false
else
  INTERACTIVE=true
fi

if [[ "$INTERACTIVE" == true ]] && ! command -v nmcli >/dev/null 2>&1; then
  ERROR_CODE="NMCLI_MISSING"
  EXIT_CODE=0
  setuphelfer_rescue_write_json "$OUT_RUN" <<EOF
{
  "checked_at": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "mode": "$MODE",
  "status": "skipped",
  "reason": "nmcli_not_available",
  "return_to_menu": true,
  "exit_code": 0,
  "secrets_exposed": false
}
EOF
  cp -f "$OUT_RUN" "$OUT_TMP" 2>/dev/null || true
  exit 0
fi

nm_active=false
if systemctl is-active --quiet NetworkManager 2>/dev/null; then
  nm_active=true
elif [[ "$EXIT_CODE" -eq 0 && "$ERROR_CODE" != "SKIPPED_QEMU_LAB" ]]; then
  systemctl start NetworkManager 2>/dev/null || true
  for _wait in $(seq 1 15); do
    systemctl is-active --quiet NetworkManager 2>/dev/null && nm_active=true && break
    sleep 1
  done
  [[ "$nm_active" == true ]] || {
    ERROR_CODE="NETWORKMANAGER_NOT_RUNNING"
    EXIT_CODE=10
  }
fi

if [[ "$EXIT_CODE" -eq 0 && "$ERROR_CODE" != "SKIPPED_QEMU_LAB" && "$nm_active" == true ]]; then
  setuphelfer_rescue_wifi_prepare_radio
  if nmcli -t -f DEVICE,TYPE,STATE device status 2>/dev/null | grep -E ':ethernet:connected$' >/dev/null || false; then
    CONFIG_SOURCE="ethernet_connected"
    DEFAULT_ROUTE=true
  elif nmcli -t -f DEVICE,TYPE,STATE device status 2>/dev/null | grep -E ':wifi:connected$' >/dev/null || false; then
    WIFI_CONNECTED=true
    CONFIG_SOURCE="already_connected"
  elif setuphelfer_rescue_wifi_connect_configured; then
    WIFI_CONNECTED=true
    CONFIG_SOURCE="prepared_env"
  elif setuphelfer_rescue_wifi_connect_known; then
    WIFI_CONNECTED=true
    CONFIG_SOURCE="known_nm_profile"
  elif nmcli -t -f DEVICE,TYPE,STATE device status 2>/dev/null | grep -E ':wifi:' >/dev/null || false; then
    if [[ "$INTERACTIVE" == true ]]; then
      _menu_rc=0
      setuphelfer_rescue_wifi_scan_and_menu || _menu_rc=$?
      if [[ "$_menu_rc" -eq 0 ]]; then
        WIFI_CONNECTED=true
        CONFIG_SOURCE="interactive_menu"
      elif [[ "$_menu_rc" -eq 21 ]]; then
        ERROR_CODE="NMCLI_MISSING"
        EXIT_CODE=0
      elif [[ "$_menu_rc" -eq 20 ]]; then
        OFFLINE_MODE=true
        ERROR_CODE="OFFLINE_BY_OPERATOR"
        EXIT_CODE=0
      else
        ERROR_CODE="WIFI_CONNECT_FAILED"
        EXIT_CODE=13
      fi
    else
      ERROR_CODE="WIFI_NOT_CONFIGURED"
      EXIT_CODE=20
    fi
    nmcli -t -f DEVICE,TYPE,STATE device status 2>/dev/null | grep -E ':wifi:connected$' >/dev/null || false && WIFI_CONNECTED=true
  else
    ERROR_CODE="WIFI_DEVICE_NOT_FOUND"
    EXIT_CODE=11
  fi

  # Only wait for a default route if we actually established (or already had) a
  # Wi-Fi connection. In the boot --non-interactive pass with no Wi-Fi configured
  # yet (WIFI_NOT_CONFIGURED / EXIT_CODE=20) there is nothing to wait for — waiting
  # the full 60s here just froze the start assistant on a blank screen BEFORE it
  # could open the interactive Wi-Fi menu. Return fast so the menu appears.
  if [[ "$DEFAULT_ROUTE" != true && "$OFFLINE_MODE" != true && "$WIFI_CONNECTED" == true ]]; then
    if setuphelfer_rescue_wait_default_route; then
      DEFAULT_ROUTE=true
    elif [[ "$EXIT_CODE" -eq 0 ]]; then
      ERROR_CODE="DEFAULT_ROUTE_MISSING"
      EXIT_CODE=14
    fi
  fi

  if [[ "$DEFAULT_ROUTE" == true ]]; then
    curl -fsS --max-time 10 "$TELEMETRY_HEALTH_URL" >/dev/null 2>&1 && TELEMETRY_OK=true
  elif [[ "$OFFLINE_MODE" == true ]]; then
    TELEMETRY_OK=false
  elif [[ "$EXIT_CODE" -eq 0 ]]; then
    ERROR_CODE="TELEMETRY_HEALTH_UNREACHABLE"
    EXIT_CODE=15
  fi
fi

_ip_json="$(ip -j addr 2>/dev/null || echo '[]')"
_route_json="$(ip -j route 2>/dev/null || echo '[]')"

setuphelfer_rescue_write_json "$OUT_RUN" <<EOF
{
  "checked_at": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "mode": "$MODE",
  "config_source": "$CONFIG_SOURCE",
  "offline_mode": $OFFLINE_MODE,
  "networkmanager_active": $nm_active,
  "wifi_connected": $WIFI_CONNECTED,
  "default_route_present": $DEFAULT_ROUTE,
  "telemetry_health_ok": $TELEMETRY_OK,
  "telemetry_health_url": "$TELEMETRY_HEALTH_URL",
  "wifi_ssid_configured": $( [[ -n "$SETUPHELFER_RESCUE_WIFI_SSID" ]] && echo true || echo false ),
  "error_code": $( [[ -n "$ERROR_CODE" ]] && printf '"%s"' "$ERROR_CODE" || printf 'null' ),
  "return_to_menu": $( [[ "$INTERACTIVE" == true ]] && echo true || echo false ),
  "ip_addr": $_ip_json,
  "ip_route": $_route_json,
  "secrets_exposed": false
}
EOF
cp -f "$OUT_RUN" "$OUT_TMP" 2>/dev/null || true
touch "${SETUPHELFER_RESCUE_STATE_DIR}/network-onboarding.done" 2>/dev/null || true

if [[ "$INTERACTIVE" == true && "$MODE" != "--boot-trigger" ]]; then
  case "$ERROR_CODE" in
    OFFLINE_BY_OPERATOR|NMCLI_MISSING|NETWORKMANAGER_NOT_RUNNING|WIFI_DEVICE_NOT_FOUND|WIFI_NOT_CONFIGURED|WIFI_CONNECT_FAILED|DEFAULT_ROUTE_MISSING|TELEMETRY_HEALTH_UNREACHABLE|"")
      EXIT_CODE=0
      ;;
  esac
fi

exit "$EXIT_CODE"
