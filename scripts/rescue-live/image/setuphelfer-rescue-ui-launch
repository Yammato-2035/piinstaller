#!/bin/bash
# Setuphelfer Rescue React shell launcher — offline-first, honest status reporting.
set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=setuphelfer-rescue-common.sh
source "${SCRIPT_DIR}/setuphelfer-rescue-common.sh"
set +e

UI_ROOT="/usr/share/setuphelfer/rescue/ui"
HTML="${UI_ROOT}/rescue.html"
PORT="${SETUPHELFER_RESCUE_UI_PORT:-8765}"
UI_URL="http://127.0.0.1:${PORT}/rescue.html"
STATUS_RUN="/run/setuphelfer/rescue-ui-status.json"
LOG_RUN="/run/setuphelfer/rescue-ui-launch.log"
SRV_PID=""

mkdir -p /run/setuphelfer "$(dirname "$LOG_RUN")" 2>/dev/null || true
exec > >(tee -a "$LOG_RUN") 2>&1

write_status() {
  local display_mode="$1" status="$2" reason="$3" browser_candidate="${4:-}" browser_started="${5:-false}" menu_visible="${6:-false}" server_started="${7:-false}"
  local payload
  payload="$(python3 - <<PY
import json
print(json.dumps({
    "schema_version": 1,
    "ui_url": ${UI_URL@Q},
    "server_started": ${server_started@Q} == "true",
    "browser_candidate": ${browser_candidate@Q},
    "browser_started": ${browser_started@Q} == "true",
    "display_mode": ${display_mode@Q},
    "menu_visible": ${menu_visible@Q} == "true",
    "status": ${status@Q},
    "reason": ${reason@Q},
    "network_required": False,
    "telemetry_required": False,
    "rescue_ui": {
        "server_status": "started" if ${server_started@Q} == "true" else "failed",
        "url": ${UI_URL@Q},
        "display_mode": ${display_mode@Q},
        "menu_visible": ${menu_visible@Q} == "true",
        "status": ${status@Q},
        "reason": ${reason@Q},
    },
    "secrets_exposed": False,
}, indent=2))
PY
)"
  printf '%s\n' "$payload" >"$STATUS_RUN"
  setuphelfer_rescue_mirror_evidence_file "$STATUS_RUN" "setuphelfer/evidence/boot/rescue-ui-status.json" 2>/dev/null || true
  setuphelfer_rescue_mirror_evidence_file "$LOG_RUN" "setuphelfer/logs/boot/rescue-ui-launch.log" 2>/dev/null || true
}

cleanup() {
  [[ -n "$SRV_PID" ]] && kill "$SRV_PID" 2>/dev/null || true
}
trap cleanup EXIT

[[ -f "$HTML" ]] || {
  write_status "failed" "failed" "missing_rescue_html" "" false false false
  echo "missing rescue UI: $HTML" >&2
  exit 2
}

cd "$UI_ROOT"
python3 -m http.server "$PORT" --bind 127.0.0.1 >>"$LOG_RUN" 2>&1 &
SRV_PID=$!
sleep 1
if ! kill -0 "$SRV_PID" 2>/dev/null; then
  write_status "failed" "failed" "http_server_failed" "" false false false
  exit 3
fi

GRAPHICAL_BROWSER=""
TEXT_BROWSER=""
for candidate in chromium chromium-browser firefox-esr firefox x-www-browser; do
  if command -v "$candidate" >/dev/null 2>&1; then
    GRAPHICAL_BROWSER="$candidate"
    break
  fi
done
for candidate in w3m links links2 lynx; do
  if command -v "$candidate" >/dev/null 2>&1; then
    TEXT_BROWSER="$candidate"
    break
  fi
done

if [[ -n "$GRAPHICAL_BROWSER" ]]; then
  write_status "kiosk" "ready" "graphical_browser_starting" "$GRAPHICAL_BROWSER" true true true
  if [[ -c /dev/tty1 ]]; then chvt 1 2>/dev/null || true; fi
  BROWSER_ARGS=(--kiosk --app="$UI_URL")
  case "$GRAPHICAL_BROWSER" in
    chromium|chromium-browser)
      # The rescue system runs as root. Chromium's setuid/namespace sandbox
      # (zygote) refuses to start as root and exits immediately -> the kiosk
      # service crash-loops every few seconds (blank screen on real hardware,
      # endless "Running as root without --no-sandbox is not supported"). See
      # crbug.com/638180. --no-sandbox is mandatory for a root kiosk.
      #
      # --disable-gpu: rescue boots on arbitrary GPUs (e.g. NVIDIA GTX 1070
      # with only nouveau/modesetting, or nomodeset/MSI-compat). HW GL can hang
      # or black-screen there; software rendering is the safe, driver-free path.
      CHROMIUM_PROFILE="/run/setuphelfer/chromium-profile"
      mkdir -p "$CHROMIUM_PROFILE" 2>/dev/null || true
      BROWSER_ARGS=(
        --no-sandbox
        --no-first-run
        --no-default-browser-check
        --disable-gpu
        --disable-dev-shm-usage
        --user-data-dir="$CHROMIUM_PROFILE"
        --kiosk
        --app="$UI_URL"
      )
      ;;
  esac
  exec "$GRAPHICAL_BROWSER" "${BROWSER_ARGS[@]}"
fi

run_fallback_tui() {
  local tty="/dev/tty1"
  [[ -c "$tty" ]] || tty="/dev/tty"
  export SETUPHELFER_RESCUE_TTY="$tty"

  if command -v whiptail >/dev/null 2>&1 && [[ -r "$tty" ]]; then
    while true; do
      _choice="$(whiptail --backtitle "Setuphelfer" --title "Setuphelfer Rettungsstick" --menu \
        "Grafische Oberfläche nicht verfügbar.\nDer Rettungsstick läuft im sicheren Notmenü.\n\nLokale UI:\n${UI_URL}" 20 74 7 \
        "1" "Status anzeigen" \
        "2" "Logs & Diagnose auf Stick schreiben" \
        "3" "Netzwerk verbinden" \
        "4" "Neustart" \
        "5" "Ausschalten" 3>&1 1>"$tty" 2>&3)" || break
      case "$_choice" in
        1)
          _summary="$(setuphelfer_rescue_summarize_ui_status "$STATUS_RUN")"
          whiptail --title "Status" --msgbox "$_summary" 18 72 3>&1 1>"$tty" 2>&3 || true
          if whiptail --title "Status" --yesno "Technische Details (JSON) anzeigen?" 8 60 3>&1 1>"$tty" 2>&3; then
            whiptail --title "Details" --scrolltext --textbox "$STATUS_RUN" 20 74 3>&1 1>"$tty" 2>&3 || true
          fi
          ;;
        2)
          write_status "fallback_tui" "review_required" "logs_refreshed" "" false true true
          setuphelfer_rescue_mirror_evidence_file "$LOG_RUN" "setuphelfer/logs/boot/rescue-ui-launch.log" 2>/dev/null || true
          setuphelfer_rescue_mirror_evidence_file "$STATUS_RUN" "setuphelfer/evidence/boot/rescue-ui-status.json" 2>/dev/null || true
          if setuphelfer_rescue_fat_esp_mount >/dev/null 2>&1; then
            whiptail --title "Logs" --msgbox "Logs unter setuphelfer/logs/boot/ und setuphelfer/evidence/boot/ auf dem Stick geschrieben (best effort)." 10 68 3>&1 1>"$tty" 2>&3 || true
          else
            whiptail --title "Logs" --msgbox "Log-Export vorbereitet. Stick-Pfad nicht gemountet — erneut versuchen, wenn der Stick erreichbar ist." 10 68 3>&1 1>"$tty" 2>&3 || true
          fi
          ;;
        3)
          setuphelfer_rescue_run_network_interactive "$tty" || true
          ;;
        4)
          systemctl reboot || true
          break
          ;;
        5)
          systemctl poweroff || true
          break
          ;;
      esac
    done
    return 0
  fi

  {
    echo ""
    echo "Setuphelfer Rettungsstick"
    echo ""
    echo "Grafische Oberfläche nicht verfügbar."
    echo "Der Rettungsstick läuft im sicheren Notmenü."
    echo ""
    echo "Lokale UI: $UI_URL"
    echo ""
    echo "1. Status anzeigen"
    echo "2. Logs & Diagnose auf Stick schreiben"
    echo "3. Netzwerk verbinden"
    echo "4. Neustart"
    echo "5. Ausschalten"
    echo ""
  } >"$tty" 2>/dev/null || true

  while true; do
    echo -n "Auswahl [1-5]: " >"$tty"
    read -r _choice <"$tty" || break
    case "$_choice" in
      1)
        setuphelfer_rescue_summarize_ui_status "$STATUS_RUN" >"$tty" 2>/dev/null || true
        ;;
      2)
        setuphelfer_rescue_mirror_evidence_file "$LOG_RUN" "setuphelfer/logs/boot/rescue-ui-launch.log" 2>/dev/null || true
        echo "Logs exportiert (best effort)." >"$tty"
        ;;
      3)
        setuphelfer_rescue_run_network_interactive "$tty" || true
        ;;
      4)
        systemctl reboot || true
        break
        ;;
      5)
        systemctl poweroff || true
        break
        ;;
      *)
        echo "Ungültige Auswahl" >"$tty"
        ;;
    esac
  done
}

if [[ -n "$TEXT_BROWSER" ]]; then
  write_status "fallback_tui" "review_required" "no_graphical_browser_using_text_browser" "$TEXT_BROWSER" false false true
  if [[ -c /dev/tty1 ]]; then chvt 1 2>/dev/null || true; fi
  exec "$TEXT_BROWSER" -g "$UI_URL"
fi

write_status "fallback_tui" "review_required" "no_graphical_browser_available_or_not_started" "" false true true
run_fallback_tui
write_status "url_only" "review_required" "no_graphical_browser_available_or_not_started" "" false false true
wait "$SRV_PID" 2>/dev/null || true
exit 0
