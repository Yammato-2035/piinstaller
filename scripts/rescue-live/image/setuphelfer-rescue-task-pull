#!/bin/bash
# Controlled task pull from telemetry server — allowlist only, no remote shell.
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=setuphelfer-rescue-common.sh
source "${SCRIPT_DIR}/setuphelfer-rescue-common.sh"

BOOT_ID="$(setuphelfer_rescue_boot_id)"
TASKS_BASE="${SETUPHELFER_RESCUE_TELEMETRY_URL}/api/rescue/telemetry/v1/tasks"
OUT_RUN="${SETUPHELFER_RESCUE_STATE_DIR}/task-pull-last.json"
OUT_TMP="/tmp/setuphelfer-rescue-task-pull-last.json"
ALLOWED_TYPES="collect_logs run_media_check run_network_check resend_telemetry show_operator_message request_operator_confirmation prepare_windows_inspect_readonly_preflight"

setuphelfer_rescue_ensure_state_dir

if ! command -v curl >/dev/null 2>&1; then
  setuphelfer_rescue_write_json "$OUT_RUN" <<EOF
{"error_code":"RESCUE_LIVE_HTTP_CLIENT_MISSING","secrets_exposed":false}
EOF
  exit 16
fi

_task_json="$(curl -fsS --max-time 10 "${TASKS_BASE}/next?boot_id=${BOOT_ID}" 2>/dev/null || true)"
if [[ -z "$_task_json" ]]; then
  setuphelfer_rescue_write_json "$OUT_RUN" <<EOF
{
  "checked_at": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "boot_id": "$BOOT_ID",
  "task_available": false,
  "secrets_exposed": false
}
EOF
  cp -f "$OUT_RUN" "$OUT_TMP" 2>/dev/null || true
  exit 0
fi

_result="$(python3 - <<PY
import json, subprocess, sys, os
from datetime import datetime, timezone

allowed = {
    "collect_logs", "run_media_check", "run_network_check", "resend_telemetry",
    "show_operator_message", "request_operator_confirmation",
    "prepare_windows_inspect_readonly_preflight",
}
task = json.loads("""$(echo "$_task_json" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))')""")
task_type = task.get("task_type")
task_id = task.get("task_id")
expires_at = task.get("expires_at")
dry_run = bool(task.get("dry_run", True))
out = {
    "task_id": task_id,
    "task_type": task_type,
    "accepted": False,
    "executed": False,
    "dry_run": dry_run,
    "result_status": "rejected",
    "message": "",
    "secrets_exposed": False,
}
if task_type not in allowed:
    out["message"] = "unknown_task_type"
    print(json.dumps(out))
    sys.exit(0)
if expires_at:
    try:
        exp = datetime.fromisoformat(expires_at.replace("Z", "+00:00"))
        if exp < datetime.now(timezone.utc):
            out["message"] = "task_expired"
            print(json.dumps(out))
            sys.exit(0)
    except Exception:
        out["message"] = "invalid_expires_at"
        print(json.dumps(out))
        sys.exit(0)
out["accepted"] = True
result_payload = {"summary": "", "artifacts": []}
script_dir = os.environ.get("SETUPHELFER_RESCUE_SCRIPT_DIR", "/usr/local/sbin")
if task_type == "collect_logs" and not dry_run:
    result_payload["summary"] = "collect_logs not executed (dry_run required for safety in v1)"
elif task_type == "run_media_check":
    rc = subprocess.call([f"{script_dir}/setuphelfer-rescue-media-check"])
    result_payload["summary"] = f"media_check exit={rc}"
    out["executed"] = True
elif task_type == "run_network_check":
    rc = subprocess.call([f"{script_dir}/setuphelfer-rescue-network-onboarding", "--non-interactive"])
    result_payload["summary"] = f"network_check exit={rc}"
    out["executed"] = True
elif task_type == "resend_telemetry":
    rc = subprocess.call([f"{script_dir}/setuphelfer-rescue-telemetry-push"])
    result_payload["summary"] = f"telemetry_push exit={rc}"
    out["executed"] = True
elif task_type == "show_operator_message":
    result_payload["summary"] = str(task.get("params", {}).get("message", ""))[:500]
    out["executed"] = True
elif task_type == "request_operator_confirmation":
    result_payload["summary"] = "operator_confirmation_required"
    out["executed"] = False
elif task_type == "prepare_windows_inspect_readonly_preflight":
    result_payload["summary"] = "preflight_only_no_windows_inspect"
    out["executed"] = True
else:
    result_payload["summary"] = f"dry_run_ok:{task_type}"
out["result_status"] = "ok" if out["accepted"] else "rejected"
out["result_payload"] = result_payload
print(json.dumps(out))
PY
)"

_task_id="$(echo "$_result" | python3 -c 'import json,sys; print(json.load(sys.stdin).get("task_id") or "")')"
if [[ -n "$_task_id" ]]; then
  curl -fsS --max-time 10 -X POST "${TASKS_BASE}/result" \
    -H 'Content-Type: application/json' \
    -d "$(python3 - <<PY
import json
base = json.loads("""$(echo "$_result" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))')""")
print(json.dumps({
  "boot_id": "$BOOT_ID",
  "task_id": base.get("task_id"),
  "task_type": base.get("task_type"),
  "result_status": base.get("result_status"),
  "result_payload": base.get("result_payload", {}),
  "dry_run": base.get("dry_run", True),
  "secrets_exposed": False,
}))
PY
)" >/dev/null 2>&1 || true
fi

setuphelfer_rescue_write_json "$OUT_RUN" <<EOF
$(echo "$_result" | python3 -m json.tool)
EOF
cp -f "$OUT_RUN" "$OUT_TMP" 2>/dev/null || true
exit 0
