#!/bin/bash
# Collect rescue diagnostics and POST to telemetry ingest (with local spool on failure).
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=setuphelfer-rescue-common.sh
source "${SCRIPT_DIR}/setuphelfer-rescue-common.sh"

setuphelfer_rescue_load_network_env || true
setuphelfer_rescue_resolve_telemetry_urls

HEALTH_URL="${SETUPHELFER_RESCUE_TELEMETRY_HEALTH_URL}"
INGEST_URL="${SETUPHELFER_RESCUE_TELEMETRY_INGEST_URL}"
SPOOL_DIR="${SETUPHELFER_RESCUE_STATE_DIR}/telemetry-spool"
ACK_RUN="${SETUPHELFER_RESCUE_STATE_DIR}/telemetry-last-ack.json"
ACK_TMP="/tmp/setuphelfer-rescue-telemetry-last-ack.json"
PAYLOAD_TMP="$(mktemp /tmp/setuphelfer-rescue-telemetry-payload.XXXXXX.json)"
BUILDER="${SCRIPT_DIR}/setuphelfer-rescue-telemetry-build-payload.py"

setuphelfer_rescue_ensure_state_dir
mkdir -p "$SPOOL_DIR"

export SETUPHELFER_RESCUE_ISO_SHA256="$(setuphelfer_rescue_iso_sha256)"

if [[ ! -x "$BUILDER" && -f "${SCRIPT_DIR}/setuphelfer-rescue-telemetry-build-payload.py" ]]; then
  chmod +x "${SCRIPT_DIR}/setuphelfer-rescue-telemetry-build-payload.py" 2>/dev/null || true
fi
if [[ ! -f "$BUILDER" ]]; then
  echo "setuphelfer-rescue-telemetry-push: missing payload builder" >&2
  exit 30
fi

if ! python3 "$BUILDER" "$PAYLOAD_TMP" 2>/tmp/setuphelfer-rescue-telemetry-build.err; then
  echo "setuphelfer-rescue-telemetry-push: payload build failed" >&2
  cat /tmp/setuphelfer-rescue-telemetry-build.err >&2 2>/dev/null || true
  rm -f "$PAYLOAD_TMP"
  exit 30
fi

_hash="$(python3 -c 'import json,sys; print(json.load(open(sys.argv[1]))["payload_hash_sha256"])' "$PAYLOAD_TMP")"
_network_ready=false
if ip route show default 2>/dev/null | grep -q .; then
  _network_ready=true
fi

if [[ "$_network_ready" != true ]]; then
  _spool="${SPOOL_DIR}/$(date +%s)-$(setuphelfer_rescue_boot_id).json"
  cp -f "$PAYLOAD_TMP" "$_spool"
  setuphelfer_rescue_write_json "$ACK_RUN" <<EOF
{
  "sent_at": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "http_status": 0,
  "spooled": true,
  "spool_path": "$_spool",
  "reason": "network_not_ready",
  "payload_hash_sha256": "$_hash",
  "secrets_exposed": false
}
EOF
  cp -f "$ACK_RUN" "$ACK_TMP" 2>/dev/null || true
  rm -f "$PAYLOAD_TMP"
  systemctl start setuphelfer-rescue-telemetry-retry.timer 2>/dev/null || true
  exit 20
fi

if ! command -v curl >/dev/null 2>&1; then
  rm -f "$PAYLOAD_TMP"
  exit 30
fi

_health_code="$(curl -sS -o /dev/null -w '%{http_code}' --max-time 10 "$HEALTH_URL" 2>/dev/null || echo 000)"
if [[ "$_health_code" != "200" ]]; then
  _spool="${SPOOL_DIR}/$(date +%s)-$(setuphelfer_rescue_boot_id).json"
  cp -f "$PAYLOAD_TMP" "$_spool"
  setuphelfer_rescue_write_json "$ACK_RUN" <<EOF
{
  "sent_at": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "http_status": $_health_code,
  "spooled": true,
  "spool_path": "$_spool",
  "reason": "health_unreachable",
  "health_url": "$HEALTH_URL",
  "payload_hash_sha256": "$_hash",
  "secrets_exposed": false
}
EOF
  cp -f "$ACK_RUN" "$ACK_TMP" 2>/dev/null || true
  rm -f "$PAYLOAD_TMP"
  systemctl start setuphelfer-rescue-telemetry-retry.timer 2>/dev/null || true
  exit 10
fi

_response="$(curl -sS -w '\n%{http_code}' --max-time 20 -X POST "$INGEST_URL" \
  -H 'Content-Type: application/json' \
  -H "X-Setuphelfer-Payload-Hash: $_hash" \
  --data-binary @"$PAYLOAD_TMP" 2>/dev/null || echo -e '\n000')"
_http_code="$(echo "$_response" | tail -1)"
_response="$(echo "$_response" | sed '$d')"

if [[ "$_http_code" == "200" ]]; then
  _hash_match=false
  if echo "$_response" | python3 -c 'import json,sys; b=json.load(sys.stdin); sys.exit(0 if b.get("hash_match") else 1)' 2>/dev/null; then
    _hash_match=true
  fi
  if [[ "$_hash_match" != true ]]; then
    setuphelfer_rescue_write_json "$ACK_RUN" <<EOF
{
  "sent_at": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "http_status": $_http_code,
  "error": "payload_hash_ack_mismatch",
  "response": $(echo "$_response" | python3 -c 'import json,sys; print(json.dumps(json.load(sys.stdin)))' 2>/dev/null || echo 'null'),
  "payload_hash_sha256": "$_hash",
  "secrets_exposed": false
}
EOF
    cp -f "$ACK_RUN" "$ACK_TMP" 2>/dev/null || true
    rm -f "$PAYLOAD_TMP"
    exit 13
  fi
  setuphelfer_rescue_write_json "$ACK_RUN" <<EOF
{
  "sent_at": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "http_status": $_http_code,
  "response": $(echo "$_response" | python3 -c 'import json,sys; print(json.dumps(json.load(sys.stdin)))' 2>/dev/null || echo 'null'),
  "payload_hash_sha256": "$_hash",
  "ack_id": $(echo "$_response" | python3 -c 'import json,sys; print(json.dumps(json.load(sys.stdin).get("ack_id")))' 2>/dev/null || echo 'null'),
  "secrets_exposed": false
}
EOF
  cp -f "$ACK_RUN" "$ACK_TMP" 2>/dev/null || true
  rm -f "$PAYLOAD_TMP"
  find "$SPOOL_DIR" -type f -name '*.json' -delete 2>/dev/null || true
  exit 0
fi

if [[ "$_http_code" == "422" ]]; then
  rm -f "$PAYLOAD_TMP"
  exit 12
fi

_spool="${SPOOL_DIR}/$(date +%s)-$(setuphelfer_rescue_boot_id).json"
cp -f "$PAYLOAD_TMP" "$_spool"
setuphelfer_rescue_write_json "$ACK_RUN" <<EOF
{
  "sent_at": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "http_status": $_http_code,
  "spooled": true,
  "spool_path": "$_spool",
  "reason": "ingest_unreachable",
  "ingest_url": "$INGEST_URL",
  "payload_hash_sha256": "$_hash",
  "secrets_exposed": false
}
EOF
cp -f "$ACK_RUN" "$ACK_TMP" 2>/dev/null || true
rm -f "$PAYLOAD_TMP"
systemctl start setuphelfer-rescue-telemetry-retry.timer 2>/dev/null || true
exit 11
