#!/bin/bash
# Setuphelfer Rescue Start Assistant — guided TUI (read-only plans, no destructive actions).
set -uo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=setuphelfer-rescue-common.sh
source "${SCRIPT_DIR}/setuphelfer-rescue-common.sh"

MODE="${1:---interactive}"
STATE_DIR="$SETUPHELFER_RESCUE_STATE_DIR"
STATUS_JSON="$(setuphelfer_rescue_start_assistant_status_path)"
MEDIA_JSON="${STATE_DIR}/media-check.json"
NETWORK_JSON="${STATE_DIR}/network-onboarding.json"
DISK_JSON="${STATE_DIR}/disk-discovery.json"
PLAN_JSON="${STATE_DIR}/action-plan.json"
WIZARD_JSON="$(setuphelfer_rescue_wizard_state_path)"
ACK_JSON="${STATE_DIR}/telemetry-last-ack.json"

setuphelfer_rescue_ensure_state_dir
setuphelfer_rescue_load_network_env || true
setuphelfer_rescue_resolve_telemetry_urls

_BOOT_EVIDENCE_STATUS="failed"
_BOOT_EVIDENCE_MODE="unknown"
if [[ -x "${SCRIPT_DIR}/setuphelfer-rescue-boot-evidence-init" ]]; then
  _boot_init_json="$("${SCRIPT_DIR}/setuphelfer-rescue-boot-evidence-init" 2>/dev/null || true)"
  if [[ -n "$_boot_init_json" ]]; then
    _BOOT_EVIDENCE_STATUS="$(python3 -c 'import json,sys; d=json.loads(sys.argv[1]); print(d.get("status","failed"))' "$_boot_init_json" 2>/dev/null || echo failed)"
    if [[ "$_BOOT_EVIDENCE_STATUS" == "stick" ]]; then
      _BOOT_EVIDENCE_MODE="Evidence: Stick"
    elif [[ "$_BOOT_EVIDENCE_STATUS" == "ram_fallback" ]]; then
      _BOOT_EVIDENCE_MODE="Evidence: RAM fallback"
    else
      _BOOT_EVIDENCE_MODE="Evidence: failed"
    fi
  fi
fi

_wizard_step="welcome"
_selected_action=""
_media_stable=false
_network_ok=false
_telemetry_ok=false
_expert_mode=false
_last_ack_id=""
_last_error_code=""
_exit_code=0
_autostart=false
_tty1_prepared=false

_status_write() {
  local phase="${1:-$_wizard_step}"
  setuphelfer_rescue_write_start_assistant_status <<EOF
{
  "schema_version": 1,
  "updated_at": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "phase": "$phase",
  "mode": "$MODE",
  "autostart": $_autostart,
  "cmdline_start_assistant": $(setuphelfer_rescue_cmdline_has_start_assistant && echo true || echo false),
  "tty1_prepared": $_tty1_prepared,
  "media_ok": $( [[ "$_media_stable" == true ]] && echo true || echo false ),
  "network_ok": $( [[ "$_network_ok" == true ]] && echo true || echo false ),
  "telemetry_ok": $( [[ "$_telemetry_ok" == true ]] && echo true || echo false ),
  "last_ack_id": $( [[ -n "$_last_ack_id" ]] && printf '"%s"' "$_last_ack_id" || printf 'null' ),
  "last_error_code": $( [[ -n "$_last_error_code" ]] && printf '"%s"' "$_last_error_code" || printf 'null' ),
  "exit_code": $_exit_code,
  "secrets_exposed": false
}
EOF
}

_on_exit() {
  local rc=$?
  _media_stable="$(setuphelfer_rescue_media_is_stable)"
  _network_ok="$(setuphelfer_rescue_network_is_ok)"
  if [[ "$rc" -ne 0 && "$_exit_code" -eq 0 ]]; then
    _exit_code="$rc"
    _last_error_code="ASSISTANT_EXIT_${rc}"
  fi
  _status_write "exit"
  if [[ "$_exit_code" -ne 0 && "$MODE" == "--boot-trigger" ]]; then
    setuphelfer_rescue_show_start_assistant_fallback >/dev/tty1 2>/dev/null || setuphelfer_rescue_show_start_assistant_fallback
  fi
}
trap _on_exit EXIT

_wizard_write_state() {
  setuphelfer_rescue_write_json "$WIZARD_JSON" <<EOF
{
  "schema_version": 1,
  "updated_at": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "step": "$_wizard_step",
  "selected_action": $( [[ -n "$_selected_action" ]] && printf '"%s"' "$_selected_action" || printf 'null' ),
  "expert_mode": $_expert_mode,
  "media_check": $( [[ -f "$MEDIA_JSON" ]] && cat "$MEDIA_JSON" || echo 'null' ),
  "network_onboarding": $( [[ -f "$NETWORK_JSON" ]] && cat "$NETWORK_JSON" || echo 'null' ),
  "disk_discovery": $( [[ -f "$DISK_JSON" ]] && cat "$DISK_JSON" || echo 'null' ),
  "action_plan": $( [[ -f "$PLAN_JSON" ]] && cat "$PLAN_JSON" || echo 'null' ),
  "write_actions_allowed": false,
  "secrets_exposed": false
}
EOF
}

_step_welcome() {
  _wizard_step="welcome"
  _status_write
  if command -v whiptail >/dev/null 2>&1 && setuphelfer_rescue_has_interactive_tty; then
    whiptail --title "Setuphelfer Rettungsstick" --msgbox "$(setuphelfer_rescue_show_branding)

Willkommen beim Setuphelfer Rettungsstick.

${_BOOT_EVIDENCE_MODE}

Der Assistent führt Sie Schritt für Schritt durch:
  • Live-Medium prüfen
  • Netzwerk verbinden
  • Telemetrie (Diagnose an Entwickler-Server)
  • Festplatten erkennen (nur lesen)
  • Sichere Empfehlung / Plan (ohne automatisches Schreiben)

OK = weiter" 22 78 3>&1 1>&2 2>&3 || return 1
    setuphelfer_rescue_ensure_telemetry_opt_in
  else
    setuphelfer_rescue_show_branding
    echo "Setuphelfer Rettungsstick — Startassistent"
    echo "${_BOOT_EVIDENCE_MODE}"
  fi
  return 0
}

_step_media() {
  _wizard_step="media_check"
  _status_write
  # The media-check.service already ran the (slow, ~45s on USB) sha256 integrity
  # check before this assistant starts (After=...media-check.service) and wrote
  # MEDIA_JSON. Re-running it here hashed 1.2 GB a second time and froze the TUI on
  # a blank screen for ~45s. Reuse the existing result; only run if it is missing.
  if [[ ! -f "$MEDIA_JSON" ]]; then
    "${SCRIPT_DIR}/setuphelfer-rescue-media-check" || true
  fi
  if [[ -f "$MEDIA_JSON" ]]; then
    _media_stable="$(setuphelfer_rescue_media_is_stable)"
  fi
  if [[ "$_media_stable" != true ]]; then
    if command -v whiptail >/dev/null 2>&1 && setuphelfer_rescue_has_interactive_tty; then
      whiptail --title "Live-Medium" --msgbox "WARNUNG: Live-Medium nicht stabil.

Empfehlung:
 • Boot-Menü: Start in RAM / Media-Check
 • USB-Stick neu schreiben
 • Keine Reparatur/Installation ausführen" 16 70 3>&1 1>&2 2>&3 || true
    fi
  fi
  _wizard_write_state
}

_step_network() {
  _wizard_step="network"
  _status_write
  local _rc=0
  if [[ "$MODE" == "--boot-trigger" ]]; then
    "${SCRIPT_DIR}/setuphelfer-rescue-network-onboarding" --non-interactive || _rc=$?
    if [[ -f "$NETWORK_JSON" ]]; then
      _network_ok="$(setuphelfer_rescue_network_is_ok)"
    fi
    if [[ "$_network_ok" != true ]]; then
      _rc=0
      "${SCRIPT_DIR}/setuphelfer-rescue-network-onboarding" --interactive || _rc=$?
    else
      _rc=0
    fi
  else
    "${SCRIPT_DIR}/setuphelfer-rescue-network-onboarding" --interactive || _rc=$?
  fi
  _network_ok="$(setuphelfer_rescue_network_is_ok)"
  if [[ "$_rc" -eq 20 && "$_network_ok" != true ]]; then
    if command -v whiptail >/dev/null 2>&1 && setuphelfer_rescue_has_interactive_tty; then
      whiptail --title "Netzwerk" --msgbox "Offline-Modus. Telemetrie wird bei Verbindung automatisch nachgesendet (Spool)." 10 60 3>&1 1>&2 2>&3 || true
    fi
  fi
  _wizard_write_state
}

_step_telemetry() {
  _wizard_step="telemetry"
  _network_ok="$(setuphelfer_rescue_network_is_ok)"
  _status_write
  local _health_ok=false
  if ip route show default 2>/dev/null | grep -q .; then
    curl -fsS --max-time 10 "${SETUPHELFER_RESCUE_TELEMETRY_HEALTH_URL}" >/dev/null 2>&1 && _health_ok=true
  fi
  if [[ "$_health_ok" != true && "$_network_ok" == true ]]; then
    _last_error_code="TELEMETRY_HEALTH_UNREACHABLE"
  fi
  "${SCRIPT_DIR}/setuphelfer-rescue-telemetry-push" || true
  systemctl start setuphelfer-rescue-telemetry-retry.timer 2>/dev/null || true
  if [[ -f "$ACK_JSON" ]]; then
    _telemetry_ok="$(python3 -c 'import json,sys; d=json.load(open(sys.argv[1])); print("true" if d.get("http_status")==200 else "false")' "$ACK_JSON" 2>/dev/null || echo false)"
    _last_ack_id="$(python3 -c 'import json,sys; d=json.load(open(sys.argv[1])); print(d.get("ack_id") or d.get("response",{}).get("ack_id") or "")' "$ACK_JSON" 2>/dev/null || echo "")"
  fi
  if command -v whiptail >/dev/null 2>&1 && setuphelfer_rescue_has_interactive_tty; then
    if [[ "$_telemetry_ok" == true && -n "$_last_ack_id" ]]; then
      whiptail --title "Telemetrie" --msgbox "Telemetrie erfolgreich gesendet.

ACK-ID: $_last_ack_id" 12 70 3>&1 1>&2 2>&3 || true
    elif [[ "$_network_ok" != true ]]; then
      whiptail --title "Telemetrie" --msgbox "Kein Netzwerk — Telemetrie wird gespoolt und später nachgesendet." 10 60 3>&1 1>&2 2>&3 || true
    else
      whiptail --title "Telemetrie" --msgbox "Telemetrie noch nicht bestätigt. Retry-Timer aktiv." 10 60 3>&1 1>&2 2>&3 || true
    fi
  fi
  _status_write
  _wizard_write_state
}

_step_disks() {
  _wizard_step="disk_discovery"
  _status_write
  export SETUPHELFER_MEDIA_STABLE="$([[ "$_media_stable" == true ]] && echo 1 || echo 0)"
  if [[ -x "${SCRIPT_DIR}/setuphelfer-rescue-disk-discovery" ]]; then
    "${SCRIPT_DIR}/setuphelfer-rescue-disk-discovery" || true
  fi
  if [[ ! -f "$DISK_JSON" ]]; then
    python3 "${SCRIPT_DIR}/setuphelfer-rescue-disk-discovery.py" "$DISK_JSON" 2>/dev/null || true
  fi
  if [[ ! -f "$DISK_JSON" ]]; then
    setuphelfer_rescue_write_json "$DISK_JSON" <<'EOF'
{
  "schema_version": 1,
  "read_only": true,
  "status": "failed",
  "error_code": "disk_discovery_failed",
  "devices": [],
  "recommendation": {"recommended_next_action": "diagnostics_only", "risks": ["disk_discovery_failed"]},
  "secrets_exposed": false
}
EOF
  fi
  _wizard_write_state
}

_step_recommendation() {
  _wizard_step="recommendation"
  _status_write
  local _rec="diagnostics_only"
  if [[ -f "$DISK_JSON" ]]; then
    _rec="$(python3 -c 'import json,sys; print(json.load(open(sys.argv[1])).get("recommendation",{}).get("recommended_next_action","diagnostics_only"))' "$DISK_JSON" 2>/dev/null || echo diagnostics_only)"
  fi
  if command -v whiptail >/dev/null 2>&1 && setuphelfer_rescue_has_interactive_tty; then
    whiptail --title "Empfehlung" --msgbox "Nächster empfohlener Schritt:\n\n$_rec\n\nBei Fehlern auf der Platte: zuerst Backup." 12 70 3>&1 1>&2 2>&3 || true
  fi
  _wizard_write_state
}

_main_menu() {
  _wizard_step="main_menu"
  _status_write
  local _choice
  while true; do
    set +e
    _choice="$(whiptail --title "Setuphelfer Rettungsstick" --menu "Was möchten Sie tun?" 20 78 12 \
      "backup" "Dateien sichern / Backup erstellen (Plan)" \
      "restore" "Letztes Backup wiederherstellen (Plan)" \
      "repair" "Fehler prüfen / Reparaturvorschlag (Plan)" \
      "install" "System neu installieren (Plan)" \
      "diagnostics" "Nur Diagnosebericht" \
      "expert" "Expertenmodus (Shell-Hinweis)" \
      "quit" "Assistent beenden" 3>&1 1>&2 2>&3)"
    local _menu_rc=$?
    set -e
    if [[ "$_menu_rc" -ne 0 ]]; then
      setuphelfer_rescue_record_menu_evidence "main_menu" "cancelled" "whiptail_exit_${_menu_rc}"
      break
    fi
    _selected_action="$_choice"
    case "$_choice" in
      backup|restore|repair|install|diagnostics)
        if [[ "$_media_stable" != true && "$_choice" != "diagnostics" ]]; then
          whiptail --msgbox "Blockiert: Live-Medium nicht stabil." 8 50 3>&1 1>&2 2>&3 || true
          setuphelfer_rescue_record_menu_evidence "$_choice" "blocked" "live_medium_unstable"
          continue
        fi
        if [[ "$_choice" == "repair" || "$_choice" == "install" ]]; then
          whiptail --msgbox "Hinweis: Zuerst Backup empfohlen. Es wird nur ein Plan erstellt — keine Ausführung." 10 60 3>&1 1>&2 2>&3 || true
        fi
        _wizard_write_state
        set +e
        python3 "${SCRIPT_DIR}/setuphelfer-rescue-plan-builder.py" "$DISK_JSON" "$WIZARD_JSON" "$PLAN_JSON"
        local _plan_rc=$?
        set -e
        if [[ "$_plan_rc" -ne 0 ]]; then
          setuphelfer_rescue_record_menu_evidence "$_choice" "error" "plan_builder_exit_${_plan_rc}"
          whiptail --msgbox "Plan-Erstellung fehlgeschlagen (Code ${_plan_rc}). Zurück zum Menü." 10 60 3>&1 1>&2 2>&3 || true
          continue
        fi
        setuphelfer_rescue_record_menu_evidence "$_choice" "ok" "plan_created"
        whiptail --title "Plan" --textbox "$PLAN_JSON" 22 78 3>&1 1>&2 2>&3 || true
        ;;
      expert)
        _expert_mode=true
        whiptail --msgbox "Expertenmodus: Shell/Tools manuell. Keine automatischen Schreibaktionen." 10 60 3>&1 1>&2 2>&3 || true
        setuphelfer_rescue_record_menu_evidence "expert" "ok" "hint_only"
        _wizard_write_state
        ;;
      quit)
        setuphelfer_rescue_record_menu_evidence "quit" "ok" ""
        if _final_actions; then
          return 2
        fi
        return 0
        ;;
      *)
        setuphelfer_rescue_record_menu_evidence "${_choice:-unknown}" "unknown" "unexpected_choice"
        ;;
    esac
  done
}

# Offer real end actions after the wizard. The service uses RemainAfterExit=yes and
# Conflicts=getty@tty1, so just exiting leaves tty1 frozen with no shell/getty — which
# looked like "quit does nothing". Returns 0 = leave (system going down), 10 = back to menu.
_final_actions() {
  local _fin _fin_rc
  if ! command -v whiptail >/dev/null 2>&1 || ! setuphelfer_rescue_has_interactive_tty; then
    return 0
  fi
  set +e
  _fin="$(whiptail --title "Setuphelfer Rettungsstick" \
    --menu "Assistent beendet — Aktion wählen:" 14 70 4 \
    "menu" "Zurück zum Assistenten-Menü" \
    "reboot" "Neustart" \
    "poweroff" "Herunterfahren" 3>&1 1>&2 2>&3)"
  _fin_rc=$?
  set -e
  if [[ "$_fin_rc" -ne 0 ]]; then
    return 10
  fi
  case "$_fin" in
    reboot)
      whiptail --infobox "Neustart wird ausgeführt…" 7 50 3>&1 1>&2 2>&3 || true
      systemctl reboot 2>/dev/null || reboot 2>/dev/null || true
      sleep 15
      return 0
      ;;
    poweroff)
      whiptail --infobox "Rechner wird heruntergefahren…" 7 50 3>&1 1>&2 2>&3 || true
      systemctl poweroff 2>/dev/null || poweroff 2>/dev/null || true
      sleep 15
      return 0
      ;;
    *)
      return 10
      ;;
  esac
}

if [[ "$MODE" == "--boot-trigger" ]]; then
  _autostart=true
  if ! setuphelfer_rescue_cmdline_has_start_assistant; then
    _exit_code=0
    exit 0
  fi
  # RS-P2A: graphical Rescue GUI is the default path when assets exist.
  # Text TUI remains the honest fallback when display/browser/backend fails.
  if [[ -f /usr/share/setuphelfer/rescue/ui/rescue.html && -x "${SCRIPT_DIR}/setuphelfer-rescue-gui-start" ]]; then
    if "${SCRIPT_DIR}/setuphelfer-rescue-gui-start"; then
      :
    fi
    _gui_rc=$?
    if [[ "$_gui_rc" -eq 0 ]]; then
      exit 0
    fi
    if command -v whiptail >/dev/null 2>&1 && setuphelfer_rescue_has_interactive_tty; then
      _wt="$(setuphelfer_rescue_whiptail_tty)"
      whiptail --title "Setuphelfer" --msgbox "Grafische Oberfläche konnte nicht gestartet werden.\n\nUrsache: gui_start_exit_${_gui_rc}\n\nDer sichere Text-Assistent wird geöffnet." 14 72 3>&1 1>"$_wt" 2>&3 || true
    fi
  fi
  if grep -qw 'setuphelfer_kiosk=1' /proc/cmdline 2>/dev/null \
     && [[ -f /usr/share/setuphelfer/rescue/ui/rescue.html && -x /usr/local/sbin/setuphelfer-rescue-kiosk-start ]]; then
    exec /usr/local/sbin/setuphelfer-rescue-kiosk-start
  fi
  if setuphelfer_rescue_prepare_tty1; then
    _tty1_prepared=true
  fi
  if [[ -c /dev/tty1 ]]; then
    exec </dev/tty1 >/dev/tty1 2>&1
  fi
  for _wait in $(seq 1 30); do
    if setuphelfer_rescue_has_interactive_tty; then
      break
    fi
    sleep 1
  done
  if ! setuphelfer_rescue_has_interactive_tty; then
    _last_error_code="TTY_NOT_READY"
    _exit_code=31
    exit 31
  fi
fi

if ! command -v whiptail >/dev/null 2>&1; then
  echo "whiptail fehlt — Startassistent benötigt dialog/whiptail" >&2
  _last_error_code="WHIPTAIL_MISSING"
  _exit_code=30
  exit 30
fi

_step_welcome || exit 0
_step_media
_step_network
_step_telemetry
_step_disks
_step_recommendation
while true; do
  set +e
  _main_menu
  _menu_rc=$?
  set -e
  if [[ "$_menu_rc" -eq 2 ]]; then
    break
  fi
done
_wizard_write_state
_status_write "completed"
setuphelfer_rescue_run_evidence_bundle
exit 0
