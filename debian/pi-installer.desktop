[Desktop Entry]
Version=1.0
Type=Application
Name=SetupHelfer
Comment=Backend prüfen, dann Auswahl: Tauri-App, Browser oder nur Backend (API)
Exec=/opt/pi-installer/scripts/start-pi-installer.sh
Path=/opt/pi-installer
Icon=/opt/pi-installer/frontend/src-tauri/icons/icon.png
Terminal=true
Categories=System;Settings;Utility;
Keywords=setuphelfer;raspberry;pi;installer;linux;
StartupWMClass=pi-installer
