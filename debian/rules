#!/usr/bin/make -f
# Setuphelfer Debian package build

%:
	dh $@

override_dh_auto_install:
	# Programmdateien nach /opt/setuphelfer (ohne Entwicklung/ Build-Artefakte)
	install -d debian/setuphelfer/opt/setuphelfer
	rsync -a --exclude='.git' \
	      --exclude='node_modules' \
	      --exclude='venv' \
	      --exclude='__pycache__' \
	      --exclude='*.pyc' \
	      --exclude='.env' \
	      --exclude='dist' \
	      --exclude='target/debug' \
	      --exclude='target/.rustc_info.json' \
	      --exclude='target/.cargo-lock' \
	      --exclude='target/**/*.rlib' \
	      --exclude='target/**/*.d' \
	      --exclude='target/**/*.o' \
	      --exclude='target/**/*.a' \
	      --exclude='debian' \
	      . debian/setuphelfer/opt/setuphelfer/
	# Tauri Binary explizit einbinden, falls vorhanden (wird beim Build erstellt)
	if [ -f frontend/src-tauri/target/release/pi-installer ]; then \
		install -d debian/setuphelfer/opt/setuphelfer/frontend/src-tauri/target/release; \
		install -m 755 frontend/src-tauri/target/release/pi-installer debian/setuphelfer/opt/setuphelfer/frontend/src-tauri/target/release/pi-installer; \
		echo "✅ Tauri Binary in Paket eingebunden"; \
	else \
		echo "⚠️  Tauri Binary nicht gefunden - Paket wird ohne Tauri Binary gebaut"; \
	fi
	# Verzeichnisplatzhalter (Inhalt in postinst)
	install -d debian/setuphelfer/etc/setuphelfer
	install -d debian/setuphelfer/var/log/setuphelfer
	install -d debian/setuphelfer/var/lib/setuphelfer
	# systemd-Services (Backend = Owner :8000; Web-UI getrennt)
	install -d debian/setuphelfer/etc/systemd/system
	install -m 644 debian/setuphelfer-backend.service debian/setuphelfer/etc/systemd/system/setuphelfer-backend.service
	install -m 644 debian/setuphelfer.service debian/setuphelfer/etc/systemd/system/setuphelfer.service
	# Umgebungsvariablen für alle Nutzer
	install -d debian/setuphelfer/etc/profile.d
	install -m 644 debian/setuphelfer.sh debian/setuphelfer/etc/profile.d/setuphelfer.sh
	# Startmenü-Einträge
	install -d debian/setuphelfer/usr/share/applications
	install -m 644 debian/setuphelfer.desktop debian/setuphelfer/usr/share/applications/setuphelfer.desktop
	install -m 644 debian/setuphelfer-browser.desktop debian/setuphelfer/usr/share/applications/setuphelfer-browser.desktop
	# Skripte ausführbar machen
	find debian/setuphelfer/opt/setuphelfer -type f -name '*.sh' -exec chmod 755 {} \;

override_dh_auto_clean:
	dh_auto_clean
	rm -rf debian/setuphelfer
