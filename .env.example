# PI-Installer Umgebungsvariablen (Kopie nach .env und anpassen)
# Siehe docs/developer/app_modes.md für APP_EDITION.

# App-Modus: release (Standard) | repo
# release = Endnutzer-Build, keine Experten-/Update-Center-Funktionen
# repo = Entwickler-Build mit Update-Center, DEB-Build, Kompatibilitätsprüfung
APP_EDITION=release

# Optional: Backend nur localhost (Standard) oder LAN
# ALLOW_REMOTE_ACCESS=true

# Optional: Backend-Port
# PI_INSTALLER_BACKEND_PORT=8000
