# PI-Installer / Setuphelfer – Umgebungsvariablen
# Kopie nach .env im Repo-Root:  cp .env.example .env
#
# Wird von scripts/start-backend.sh und start.sh eingelesen (set -a; . ./.env).
# Backend liest APP_EDITION und weitere Variablen zur Laufzeit aus os.environ.
#
# Siehe: docs/developer/app_modes.md (APP_EDITION), backend/core/install_paths.py (Pfade)

# --- App-Modus (zentral) ---
# release = Endnutzer | repo = Entwickler (Update-Center, Experten-UI)
APP_EDITION=release

# --- Entwicklung ---
# 1 = Dev-Pfade (~/.config/setuphelfer, ~/.local/share/…), optional --reload über start.sh / start-backend.sh
# PI_INSTALLER_DEV=1

# --- Backend-Netzwerk ---
# true/1: Backend auf 0.0.0.0 (LAN); sonst nur 127.0.0.1
# ALLOW_REMOTE_ACCESS=true

# --- Backend-Port (Standard 8000) ---
# Wichtig parallel zu setuphelfer-backend.service: anderen Port wählen, z. B. 8010
# PI_INSTALLER_BACKEND_PORT=8000

# --- Parallel zu installiertem Dienst auf :8000 ---
# Nur setzen, wenn bewusst ein zweites Repo-Backend gestartet wird (anderer Port empfohlen)
# PI_INSTALLER_SKIP_SERVICE_CONFLICT_GUARD=1
# SETUPHELFER_SKIP_SERVICE_CONFLICT_GUARD=1

# --- Installations-/Service-Pfade (normalerweise nur unter systemd gesetzt) ---
# SETUPHELFER_DIR=/opt/setuphelfer
# PI_INSTALLER_DIR=/opt/setuphelfer
# SETUPHELFER_CONFIG_DIR=/etc/setuphelfer
# SETUPHELFER_STATE_DIR=/var/lib/setuphelfer
# SETUPHELFER_LOG_DIR=/var/log/setuphelfer

# --- CORS / Host (optional, kommasepariert) ---
# PI_INSTALLER_CORS_ORIGINS=http://192.168.1.10:3001
# PI_INSTALLER_ALLOWED_HOSTS=192.168.1.10

# --- Venv ---
# PI_INSTALLER_SKIP_VENV_SYNC=1

# --- Frontend (Vite) ---
# Liegt unter frontend/: Datei .env.development (siehe frontend/.env.development.example)
# VITE_PROXY_TARGET=http://127.0.0.1:8000   # bei abweichendem Backend-Port anpassen
# VITE_API_BASE=   # nur für gebündelten Build gegen Remote-API
# VITE_APP_EDITION=repo   # Build-Zeit; Laufzeit folgt /api/system-info

# --- Vite-Cache (Produktion/Service-User) ---
# PI_INSTALLER_VITE_CACHE_DIR=/tmp/setuphelfer-vite-cache

# --- Backup-Erfolg: E-Mail-Benachrichtigung (optional) ---
# Keine Secrets ins Repo committen. Werte nur in .env oder systemd EnvironmentFile setzen.
# SETUPHELFER_NOTIFY_EMAIL_ENABLED=false
# SETUPHELFER_NOTIFY_EMAIL_TO=
# SETUPHELFER_NOTIFY_EMAIL_FROM=
# SETUPHELFER_NOTIFY_SMTP_HOST=
# SETUPHELFER_NOTIFY_SMTP_PORT=587
# SETUPHELFER_NOTIFY_SMTP_USERNAME=
# SETUPHELFER_NOTIFY_SMTP_PASSWORD=
# SETUPHELFER_NOTIFY_SMTP_STARTTLS=true
# SETUPHELFER_NOTIFY_ON_BACKUP_SUCCESS=true
# SETUPHELFER_NOTIFY_ON_BACKUP_FAILURE=false
