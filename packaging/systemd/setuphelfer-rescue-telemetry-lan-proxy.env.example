# Optional operator overrides for setuphelfer-rescue-telemetry-lan-proxy.service
# Install:
#   sudo cp packaging/systemd/setuphelfer-rescue-telemetry-lan-proxy.env.example \
#     /etc/setuphelfer/rescue-telemetry-lan-proxy.env
#   sudo systemctl daemon-reload
#   sudo systemctl restart setuphelfer-rescue-telemetry-lan-proxy

# Pin LAN bind IP when auto-detect picks the wrong interface (e.g. Wi-Fi vs Ethernet).
# SETUPHELFER_RESCUE_TELEMETRY_BIND=192.168.178.140

# SETUPHELFER_RESCUE_TELEMETRY_PORT=8001
# SETUPHELFER_RESCUE_TELEMETRY_UPSTREAM=http://127.0.0.1:8000
# SETUPHELFER_RESCUE_TELEMETRY_TASK_PULL_ENABLED=1
