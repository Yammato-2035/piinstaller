# Developer-only timer — standardmäßig NICHT aktivieren.
# Intervall anpassbar (OnUnitActiveSec).

[Unit]
Description=Run Setuphelfer developer backend healthcheck periodically

[Timer]
OnBootSec=2min
OnUnitActiveSec=60s
AccuracySec=30s
Persistent=true
Unit=setuphelfer-dev-healthcheck.service

[Install]
WantedBy=timers.target
