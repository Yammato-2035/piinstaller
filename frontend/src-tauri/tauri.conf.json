{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SetupHelfer",
  "version": "1.5.0",
  "identifier": "de.pi-installer.app",
  "build": {
    "beforeDevCommand": "npm run dev:tauri-with-backend",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "VITE_API_BASE=http://127.0.0.1:8000 npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "SetupHelfer",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "resources": [
      "../public/assets/branding/icon/app-icon-source.svg",
      "../public/assets/branding/splash/splash-source.svg"
    ],
    "externalBin": [],
    "copyright": "",
    "category": "Utility",
    "shortDescription": "SetupHelfer – Desktop-Oberfläche für Raspberry Pi & Linux",
    "longDescription": "SetupHelfer als eigenständige Desktop-Anwendung. Verbindet sich mit dem Backend (Standard: http://localhost:8000).",
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
