# Vite lädt diese Datei als frontend/.env.development (nicht versioniert: .gitignore).
# Standard-Proxy in vite.config.ts: http://127.0.0.1:8000
#
# Wenn das Repo-Backend auf einem anderen Port läuft (z. B. PI_INSTALLER_BACKEND_PORT=8010):
# VITE_PROXY_TARGET=http://127.0.0.1:8010
#
# Build-Zeit (selten nötig im Dev): VITE_APP_EDITION=repo | release
