{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://setuphelfer.local/schemas/windows_inspect.schema.json",
  "title": "Windows Rescue Inspect Report",
  "type": "object",
  "required": ["schema_version", "generated_at", "source", "safety", "host", "storage", "windows_paths", "registry_findings", "boot_findings", "logs", "findings", "recommended_actions", "backup_selection", "dualboot_readiness"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "source": { "type": "string", "const": "setuphelfer_rescue_inspect" },
    "safety": {
      "type": "object",
      "required": ["mode", "write_actions_allowed", "cloud_upload_allowed"],
      "properties": {
        "mode": { "type": "string", "enum": ["read_only"] },
        "write_actions_allowed": { "type": "boolean", "const": false },
        "bitlocker_locked": { "type": ["boolean", "null"] },
        "cloud_upload_allowed": { "type": "boolean", "const": false }
      }
    },
    "host": {
      "type": "object",
      "properties": {
        "detected_os_family": { "type": "string" },
        "edition": { "type": ["string", "null"] },
        "build": { "type": ["string", "null"] },
        "insider_or_beta_hint": { "type": ["string", "null"] },
        "computer_name": { "type": ["string", "null"] }
      }
    },
    "storage": {
      "type": "object",
      "properties": {
        "disks": { "type": "array" },
        "partitions": { "type": "array" },
        "efi_partition": { "type": ["object", "null"] },
        "windows_partition": { "type": ["object", "null"] },
        "bitlocker": { "type": "array" }
      }
    },
    "windows_paths": {
      "type": "object",
      "properties": {
        "windows_dir": { "type": ["string", "null"] },
        "system32_dir": { "type": ["string", "null"] },
        "explorer_exe": {
          "type": "object",
          "properties": {
            "path": { "type": ["string", "null"] },
            "exists": { "type": ["boolean", "null"] },
            "size": { "type": ["integer", "null"] },
            "diagnostic_code": { "type": ["string", "null"] }
          }
        }
      }
    },
    "registry_findings": {
      "type": "object",
      "properties": {
        "software_hive_readable": { "type": ["boolean", "null"] },
        "system_hive_readable": { "type": ["boolean", "null"] },
        "winlogon_shell": { "type": ["string", "null"] },
        "winlogon_userinit": { "type": ["string", "null"] },
        "profile_list": { "type": "array" }
      }
    },
    "boot_findings": {
      "type": "object",
      "properties": {
        "efi_present": { "type": ["boolean", "null"] },
        "bcd_present": { "type": ["boolean", "null"] },
        "winre_present": { "type": ["boolean", "null"] },
        "reagent_xml_present": { "type": ["boolean", "null"] }
      }
    },
    "logs": {
      "type": "object",
      "properties": {
        "cbs_log_present": { "type": ["boolean", "null"] },
        "dism_log_present": { "type": ["boolean", "null"] },
        "setupact_log_present": { "type": ["boolean", "null"] },
        "event_logs_present": { "type": "array", "items": { "type": "string" } }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "severity"],
        "properties": {
          "code": { "type": "string" },
          "severity": { "type": "string", "enum": ["info", "warning", "critical"] },
          "evidence_source": { "type": "string" },
          "explanation_de": { "type": "string" },
          "explanation_en": { "type": "string" }
        }
      }
    },
    "recommended_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "write_action_allowed"],
        "properties": {
          "code": { "type": "string" },
          "title_de": { "type": "string" },
          "title_en": { "type": "string" },
          "write_action_allowed": { "type": "boolean", "const": false }
        }
      }
    },
    "backup_selection": {
      "type": "object",
      "required": ["dry_run_only"],
      "properties": {
        "dry_run_only": { "type": "boolean", "const": true },
        "selected_paths": { "type": "array", "items": { "type": "string" } },
        "excluded_paths": { "type": "array", "items": { "type": "string" } },
        "estimated_size_bytes": { "type": ["integer", "null"] },
        "manifest_path": { "type": ["string", "null"] }
      }
    },
    "dualboot_readiness": {
      "type": "object",
      "properties": {
        "status": { "type": "string" },
        "blockers": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
