# Setuphelfer Development Agent — Rescue Developer QEMU Lab (local_lab)
# QEMU user NAT host gateway only — not for public rescue.

SETUPHELFER_DEV_AGENT_ENABLED=true
SETUPHELFER_DEV_AGENT_MODE=local_lab
SETUPHELFER_DEV_AGENT_AUTO_UPLOAD=true
SETUPHELFER_DEV_AGENT_SERVER_URL=http://10.0.2.2:8001
SETUPHELFER_DEV_AGENT_QEMU_HOST_FALLBACK=true
SETUPHELFER_DEV_AGENT_QEMU_HOST_URL=http://10.0.2.2:8001
SETUPHELFER_DEV_AGENT_COLLECT_STORAGE=true
SETUPHELFER_DEV_AGENT_COLLECT_BOOT=true
SETUPHELFER_DEV_AGENT_COLLECT_HARDWARE=true
SETUPHELFER_DEV_AGENT_TIMEOUT_SECONDS=5
